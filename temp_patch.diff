+
+    private static bool TryGetPositivePopupPreviewInternal(int gemType, int matchCount, string element, int maxHp, out string statType, out int amount)
+    {
+        statType = null;
+        amount = 0;
+
+        int safeMatchCount = Mathf.Max(1, matchCount);
+
+        switch (gemType)
+        {
+            case RageItemId:
+                statType = "Rage";
+                amount = Mathf.Max(0, safeMatchCount * ElementResourceGainConfig.GetRagePerGem(element));
+                return amount > 0;
+
+            case HealItemId:
+                statType = "HP";
+                amount = Mathf.Max(0, Mathf.RoundToInt(maxHp * 0.02f * safeMatchCount));
+                return amount > 0;
+
+            case ManaItemId:
+                statType = "Mana";
+                amount = Mathf.Max(0, safeMatchCount * ElementResourceGainConfig.GetManaPerGem(element));
+                return amount > 0;
+        }
+
