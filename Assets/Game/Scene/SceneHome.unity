  - id: FullScreen
    en: FullScreen
    jp: "\u30D5\u30EB\u30B9\u30AF\u30EA\u30FC\u30F3"
    kr: "\uC804\uCCB4 \uD654\uBA74"
    cn: "\u5168\u5C4F"
    vn: "To\xE0n m\xE0n h\xECnh"
  - id: Language
    en: Language
    jp: "\u8A00\u8A9E"
    kr: "\uC5B8\uC5B4"
    cn: "\u8BED\u8A00"
    vn: "Ng\xF4n ng\u1EEF"
  - id: Close
    en: Close
    jp: "\u9589\u3058\u308B"
    kr: "\uB2EB\uAE30"
    cn: "\u5173\u95ED"
    vn: "\u0110\xF3ng"
  - id: Card
    en: Card
    jp: "\u30AB\u30FC\u30C9"
    kr: "\uCE74\uB4DC"
    cn: "\u5361\u724C"
    vn: "Th\u1EBB"
  - id: Gem
    en: Gem
    jp: "\u30B8\u30A7\u30E0"
    kr: "\uBCF4\uC11D"
    cn: "\u5B9D\u77F3"
    vn: "Ng\u1ECDc"
  - id: Tutorial1
    en: Welcome to the World of Rune, traveler! I'm Nana, your guide. What should
      I call you?
    jp: "\u30EB\u30FC\u30F3\u306E\u4E16\u754C\u3078\u3088\u3046\u3053\u305D\u3001\u65C5\u4EBA\u3055\u3093\uFF01\u79C1\u306F\u3042\u306A\u305F\u306E\u6848\u5185\u5F79\u3001\u30CA\u30CA\u3067\u3059\u3002\u3042\u306A\u305F\u306E\u304A\u540D\u524D\u306F\u4F55\u3067\u3059\u304B\uFF1F"
    kr: "\uB8EC\uC758 \uC138\uACC4\uC5D0 \uC624\uC2E0 \uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4,
      \uC5EC\uD589\uC790\uB2D8! \uC800\uB294 \uC548\uB0B4\uC790 \uB098\uB098\uC608\uC694.
      \uBB50\uB77C\uACE0 \uBD80\uB974\uBA74 \uB420\uAE4C\uC694?"
    cn: "\u6B22\u8FCE\u6765\u5230\u7B26\u6587\u4E16\u754C\uFF0C\u65C5\u884C\u8005\uFF01\u6211\u662F\u4F60\u7684\u5411\u5BFC\u5A1C\u5A1C\u3002\u8BE5\u600E\u4E48\u79F0\u547C\u4F60\uFF1F"
    vn: "Ch\xE0o m\u1EEBng \u0111\u1EBFn v\u1EDBi Th\u1EBF gi\u1EDBi Rune, l\u1EEF
      kh\xE1ch! T\xF4i l\xE0 Nana, ng\u01B0\u1EDDi h\u01B0\u1EDBng d\u1EABn c\u1EE7a
      b\u1EA1n. T\xF4i n\xEAn g\u1ECDi b\u1EA1n l\xE0 g\xEC?"
  - id: Tutorial2
    en: Pick one of these three pets to aid your adventure in the World of Rune.
    jp: "\u30EB\u30FC\u30F3\u306E\u4E16\u754C\u3067\u306E\u5192\u967A\u3092\u52A9\u3051\u3066\u304F\u308C\u308B3\u5339\u306E\u30DA\u30C3\u30C8\u304B\u30891\u5339\u3092\u9078\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
    kr: "\uB8EC\uC758 \uC138\uACC4\uC5D0\uC11C \uBAA8\uD5D8\uC744 \uB3C4\uC640\uC904
      \uC138 \uB9C8\uB9AC \uD3AB \uC911 \uD558\uB098\uB97C \uC120\uD0DD\uD558\uC138\uC694."
    cn: "\u4ECE\u8FD9\u4E09\u53EA\u5BA0\u7269\u4E2D\u9009\u62E9\u4E00\u53EA\uFF0C\u5E2E\u52A9\u4F60\u5728\u7B26\u6587\u4E16\u754C\u4E2D\u5192\u9669\u3002"
    vn: "Ch\u1ECDn m\u1ED9t trong ba th\xFA c\u01B0ng n\xE0y \u0111\u1EC3 h\u1ED7
      tr\u1EE3 chuy\u1EBFn phi\xEAu l\u01B0u c\u1EE7a b\u1EA1n trong Th\u1EBF gi\u1EDBi
      Rune."
  - id: Tutorial3
    en: Tutorial4
    jp: Tutorial5
    kr: Tutorial6
    cn: Tutorial7
    vn: Tutorial8
  - id: Setting
    en: Setting
    jp: "\u8A2D\u5B9A"
    kr: "\uC124\uC815"
    cn: "\u8BBE\u7F6E"
    vn: "C\xE0i \u0111\u1EB7t"
  - id: Forge
    en: Forge
    jp: "\u935B\u51B6\u5834"
    kr: "\uB300\uC7A5\uAC04"
    cn: "\u953B\u9020"
    vn: "L\xF2 r\xE8n"
  - id: Training
    en: Training
    jp: "\u30C8\u30EC\u30FC\u30CB\u30F3\u30B0"
    kr: "\uD6C8\uB828"
    cn: "\u8BAD\u7EC3"
    vn: "Hu\u1EA5n luy\u1EC7n"
  - id: inpNameHolder
    en: Enter your name
    jp: "\u540D\u524D\u3092\u5165\u529B"
    kr: "\uC774\uB984\uC744 \uC785\uB825\uD558\uC138\uC694"
    cn: "\u8F93\u5165\u4F60\u7684\u540D\u5B57"
    vn: "Nh\u1EADp t\xEAn c\u1EE7a b\u1EA1n"
  - id: Continue
    en: Continue
    jp: "\u7D9A\u3051\u308B"
    kr: "\uACC4\uC18D"
    cn: "\u7EE7\u7EED"
    vn: "Ti\u1EBFp t\u1EE5c"
  - id: Back
    en: Back
    jp: "\u623B\u308B"
    kr: "\uB4A4\uB85C"
    cn: "\u8FD4\u56DE"
    vn: "Quay l\u1EA1i"
  - id: ChangePet
    en: Change Pet
    jp: "\u30DA\u30C3\u30C8\u3092\u5909\u66F4"
    kr: "\uD3AB \uBCC0\uACBD"
    cn: "\u66F4\u6362\u5BA0\u7269"
    vn: "\u0110\u1ED5i th\xFA c\u01B0ng"
  - id: Upgrade
    en: Upgrade
    jp: "\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC"
    cn: "\u5347\u7EA7"
    vn: "N\xE2ng c\u1EA5p"
  - id: pet_training_level_format
    en: Lv. {0}
    jp: 'Lv: {0}'
    kr: 'Lv: {0}'
    cn: "\u7B49\u7EA7\uFF1A{0}"
    vn: "C\u1EA5p: {0}"
  - id: pet_training_upgrade_max
    en: Pet has reached the maximum level.
    jp: "\u30DA\u30C3\u30C8\u306F\u6700\u5927\u30EC\u30D9\u30EB\u306B\u9054\u3057\u3066\u3044\u307E\u3059\u3002"
    kr: "\uD3AB\uC774 \uCD5C\uB300 \uB808\uBCA8\uC5D0 \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4."
    cn: "\u5BA0\u7269\u5DF2\u8FBE\u5230\u6700\u9AD8\u7B49\u7EA7\u3002"
    vn: "Pet \u0111\xE3 \u0111\u1EA1t c\u1EA5p t\u1ED1i \u0111a."
  - id: pet_training_no_player_data
    en: Not enough player data.
    jp: "\u30D7\u30EC\u30A4\u30E4\u30FC\u30C7\u30FC\u30BF\u304C\u4E0D\u8DB3\u3057\u3066\u3044\u307E\u3059\u3002"
    kr: "\uD50C\uB808\uC774\uC5B4 \uB370\uC774\uD130\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u73A9\u5BB6\u6570\u636E\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng c\xF3 d\u1EEF li\u1EC7u ng\u01B0\u1EDDi ch\u01A1i."
  - id: pet_training_missing_gem_system
    en: Upgrade gem system is missing.
    jp: "\u5F37\u5316\u30B8\u30A7\u30E0\u30B7\u30B9\u30C6\u30E0\u304C\u898B\u3064\u304B\u308A\u307E\u305B\u3093\u3002"
    kr: "\uAC15\uD654 \uC82C \uC2DC\uC2A4\uD15C\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
    cn: "\u7F3A\u5C11\u5347\u7EA7\u5B9D\u77F3\u7CFB\u7EDF\u3002"
    vn: "Thi\u1EBFu h\u1EC7 th\u1ED1ng gem n\xE2ng c\u1EA5p."
  - id: pet_training_need_gem
    en: Select at least 1 gem to upgrade.
    jp: "\u5F37\u5316\u3059\u308B\u30B8\u30A7\u30E0\u30921\u3064\u4EE5\u4E0A\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
    kr: "\uAC15\uD654\uD560 \uC82C\uC744 1\uAC1C \uC774\uC0C1 \uC120\uD0DD\uD558\uC138\uC694."
    cn: "\u8BF7\u81F3\u5C11\u9009\u62E9 1 \u4E2A\u5B9D\u77F3\u8FDB\u884C\u5347\u7EA7\u3002"
    vn: "C\u1EA7n ch\u1ECDn \xEDt nh\u1EA5t 1 gem \u0111\u1EC3 n\xE2ng c\u1EA5p."
  - id: pet_training_not_enough_gems
    en: Not enough gems in inventory.
    jp: "\u30A4\u30F3\u30D9\u30F3\u30C8\u30EA\u306E\u30B8\u30A7\u30E0\u304C\u8DB3\u308A\u307E\u305B\u3093\u3002"
    kr: "\uC778\uBCA4\uD1A0\uB9AC\uC5D0 \uC82C\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u80CC\u5305\u4E2D\u7684\u5B9D\u77F3\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng \u0111\u1EE7 gem trong t\xFAi \u0111\u1ED3."
  - id: pet_training_upgrade_success
    en: Upgrade successful!
    jp: "\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u6210\u529F\uFF01"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC \uC131\uACF5!"
    cn: "\u5347\u7EA7\u6210\u529F\uFF01"
    vn: "N\xE2ng c\u1EA5p th\xE0nh c\xF4ng!"
  - id: pet_training_upgrade_fail
    en: Upgrade failed!
    jp: "\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u5931\u6557\uFF01"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC \uC2E4\uD328!"
    cn: "\u5347\u7EA7\u5931\u8D25\uFF01"
    vn: "N\xE2ng c\u1EA5p th\u1EA5t b\u1EA1i!"
  - id: Clear
    en: Clear
    jp: "\u30AF\u30EA\u30A2"
    kr: "\uD074\uB9AC\uC5B4"
    cn: "\u6E05\u9664"
    vn: "X\xF3a"
  - id: Buy
    en: Buy
    jp: "\u8CFC\u5165"
    kr: "\uAD6C\uB9E4"
    cn: "\u8D2D\u4E70"
    vn: Mua
  - id: Info
    en: Info
    jp: "\u60C5\u5831"
    kr: "\uC815\uBCF4"
    cn: "\u4FE1\u606F"
    vn: "Th\xF4ng tin"
  - id: Map_Name_1
