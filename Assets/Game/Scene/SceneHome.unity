    jp: "\u30B9\u30E9\u30A4\u30E0"
    kr: "\uC2AC\uB77C\uC784"
    cn: "\u53F2\u83B1\u59C6"
    vn: Slime
  - id: Map_Name_6
    en: Sword Shadow
    jp: "\u30BD\u30FC\u30C9\u30B7\u30E3\u30C9\u30A6"
    kr: "\uC18C\uB4DC \uC100\uB3C4\uC6B0"
