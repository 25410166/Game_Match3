  - id: forge_gem_need_two_or_three
    en: "Select 2\u20133 gems."
    jp: "\u30B8\u30A7\u30E0\u30922\u301C3\u500B\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
    kr: "\uC82C\uC744 2~3\uAC1C \uC120\uD0DD\uD558\uC138\uC694."
    cn: "\u8BF7\u9009\u62E9 2\u20133 \u4E2A\u5B9D\u77F3\u3002"
    vn: "C\u1EA7n ch\u1ECDn 2-3 gem."
  - id: forge_gem_upgrade_critical
    en: Critical success! Gem Lv.{0}
    jp: "\u5927\u6210\u529F\uFF01\u30B8\u30A7\u30E0 Lv.{0}"
    kr: "\uB300\uC131\uACF5! \uC82C Lv.{0}"
    cn: "\u66B4\u51FB\u6210\u529F\uFF01\u5B9D\u77F3 Lv.{0}"
    vn: "Th\xE0nh c\xF4ng ch\xED m\u1EA1ng! Gem Lv.{0}"
  - id: forge_gem_upgrade_success
    en: Upgrade successful! Gem Lv.{0}
    jp: "\u5F37\u5316\u6210\u529F\uFF01\u30B8\u30A7\u30E0 Lv.{0}"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC \uC131\uACF5! \uC82C Lv.{0}"
    cn: "\u5347\u7EA7\u6210\u529F\uFF01\u5B9D\u77F3 Lv.{0}"
    vn: "N\xE2ng c\u1EA5p th\xE0nh c\xF4ng! Gem Lv.{0}"
  - id: forge_gem_upgrade_fail_return
    en: "Upgrade failed \u2014 randomly returns 1\u20132 gems."
    jp: "\u5F37\u5316\u5931\u6557 - \u30E9\u30F3\u30C0\u30E0\u3067\u30B8\u30A7\u30E0\u30921\u301C2\u500B\u8FD4\u5374\u3057\u307E\u3059\u3002"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC \uC2E4\uD328 - \uC82C 1~2\uAC1C\uB97C \uBB34\uC791\uC704\uB85C
      \uBC18\uD658\uD569\uB2C8\uB2E4."
    cn: "\u5347\u7EA7\u5931\u8D25 - \u968F\u673A\u8FD4\u8FD8 1\u20132 \u4E2A\u5B9D\u77F3\u3002"
    vn: "N\xE2ng c\u1EA5p th\u1EA5t b\u1EA1i - tr\u1EA3 l\u1EA1i ng\u1EABu nhi\xEAn
      1-2 gem."
  - id: forge_gem_select_slot_order
    en: Select the gem in the previous slot before unlocking this slot.
    jp: "\u3053\u306E\u30B9\u30ED\u30C3\u30C8\u3092\u89E3\u653E\u3059\u308B\u524D\u306B\u3001\u524D\u306E\u30B9\u30ED\u30C3\u30C8\u306E\u30B8\u30A7\u30E0\u3092\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
    kr: "\uC774 \uC2AC\uB86F\uC744 \uC5F4\uAE30 \uC804\uC5D0 \uC774\uC804 \uC2AC\uB86F\uC758
      \uC82C\uC744 \uC120\uD0DD\uD558\uC138\uC694."
    cn: "\u8BF7\u5148\u9009\u62E9\u524D\u4E00\u4E2A\u69FD\u4F4D\u7684\u5B9D\u77F3\uFF0C\u518D\u89E3\u9501\u6B64\u69FD\u4F4D\u3002"
    vn: "H\xE3y ch\u1ECDn gem \u1EDF slot tr\u01B0\u1EDBc tr\u01B0\u1EDBc khi m\u1EDF
      slot n\xE0y."
  - id: forge_gem_not_enough_level_qty
    en: Not enough gems of this level.
    jp: "\u3053\u306E\u30EC\u30D9\u30EB\u306E\u30B8\u30A7\u30E0\u304C\u8DB3\u308A\u307E\u305B\u3093\u3002"
    kr: "\uC774 \uB808\uBCA8\uC758 \uC82C \uC218\uB7C9\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u6B64\u7B49\u7EA7\u7684\u5B9D\u77F3\u6570\u91CF\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng \u0111\u1EE7 s\u1ED1 l\u01B0\u1EE3ng gem level n\xE0y."
