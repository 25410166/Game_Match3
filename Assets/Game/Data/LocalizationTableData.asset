    jp: "\u5F37\u5316\u3059\u308B\u30B8\u30A7\u30E0\u304C\u8DB3\u308A\u307E\u305B\u3093\u3002"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC\uD560 \uC82C\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
