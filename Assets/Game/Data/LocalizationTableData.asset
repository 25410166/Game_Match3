    kr: "PlayerManager\uB97C \uCC3E\uC744 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    cn: "\u672A\u627E\u5230 PlayerManager\u3002"
    vn: "Kh\xF4ng t\xECm th\u1EA5y PlayerManager."
  - id: player_name_popup_invalid_name_format
    en: Name can be up to 24 characters and may contain only letters, numbers, and
      spaces.
    jp: "\u540D\u524D\u306F24\u6587\u5B57\u4EE5\u5185\u3067\u3001\u6587\u5B57\u30FB\u6570\u5B57\u30FB\u30B9\u30DA\u30FC\u30B9\u306E\u307F\u4F7F\u7528\u3067\u304D\u307E\u3059\u3002"
    kr: "\uC774\uB984\uC740 \uCD5C\uB300 24\uC790\uC774\uBA70, \uBB38\uC790/\uC22B\uC790/\uACF5\uBC31\uB9CC
      \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    cn: "\u540D\u79F0\u6700\u591A 24 \u4E2A\u5B57\u7B26\uFF0C\u53EA\u80FD\u5305\u542B\u5B57\u6BCD\u3001\u6570\u5B57\u548C\u7A7A\u683C\u3002"
    vn: "T\xEAn t\u1ED1i \u0111a 24 k\xFD t\u1EF1, ch\u1EC9 g\u1ED3m ch\u1EEF/s\u1ED1
      v\xE0 kho\u1EA3ng tr\u1EAFng."
