  - id: pet_training_upgrade_max
    en: Pet has reached its maximum level.
    jp: "\u30DA\u30C3\u30C8\u306F\u6700\u5927\u30EC\u30D9\u30EB\u306B\u9054\u3057\u3066\u3044\u307E\u3059\u3002"
    kr: "\uD3AB\uC774 \uC774\uBBF8 \uCD5C\uB300 \uB808\uBCA8\uC5D0 \uB3C4\uB2EC\uD588\uC2B5\uB2C8\uB2E4."
    cn: "\u5BA0\u7269\u5DF2\u8FBE\u5230\u6700\u9AD8\u7B49\u7EA7\u3002"
    vn: "Th\xFA c\u01B0ng \u0111\xE3 \u0111\u1EA1t c\u1EA5p t\u1ED1i \u0111a."
  - id: pet_training_no_player_data
    en: No user data.
    jp: "\u30E6\u30FC\u30B6\u30FC\u30C7\u30FC\u30BF\u304C\u3042\u308A\u307E\u305B\u3093\u3002"
    kr: "\uC0AC\uC6A9\uC790 \uB370\uC774\uD130\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4."
    cn: "\u6CA1\u6709\u7528\u6237\u6570\u636E\u3002"
    vn: "Kh\xF4ng c\xF3 d\u1EEF li\u1EC7u ng\u01B0\u1EDDi d\xF9ng."
  - id: pet_training_missing_gem_system
    en: Missing system gem upgrade.
    jp: "\u30B8\u30A7\u30E0\u5F37\u5316\u30B7\u30B9\u30C6\u30E0\u304C\u898B\u3064\u304B\u308A\u307E\u305B\u3093\u3002"
    kr: "\uBCF4\uC11D \uC5C5\uADF8\uB808\uC774\uB4DC \uC2DC\uC2A4\uD15C\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
    cn: "\u7F3A\u5C11\u5B9D\u77F3\u5347\u7EA7\u7CFB\u7EDF\u3002"
    vn: "Thi\u1EBFu h\u1EC7 th\u1ED1ng n\xE2ng c\u1EA5p ng\u1ECDc."
  - id: pet_training_need_gem
    en: Requires selecting at least one gem for upgrade.
    jp: "\u5F37\u5316\u3059\u308B\u30B8\u30A7\u30E0\u3092\u5C11\u306A\u304F\u3068\u30821\u3064\u9078\u629E\u3059\u308B\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u3002"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC\uD560 \uBCF4\uC11D\uC744 \uCD5C\uC18C 1\uAC1C
      \uC120\uD0DD\uD574\uC57C \uD569\uB2C8\uB2E4."
    cn: "\u9700\u8981\u81F3\u5C11\u9009\u62E9\u4E00\u9897\u5B9D\u77F3\u8FDB\u884C\u5347\u7EA7\u3002"
    vn: "C\u1EA7n ch\u1ECDn \xEDt nh\u1EA5t m\u1ED9t vi\xEAn ng\u1ECDc \u0111\u1EC3
      n\xE2ng c\u1EA5p."
  - id: pet_training_not_enough_gems
    en: Insufficient gems in inventory.
    jp: "\u30A4\u30F3\u30D9\u30F3\u30C8\u30EA\u5185\u306E\u30B8\u30A7\u30E0\u304C\u4E0D\u8DB3\u3057\u3066\u3044\u307E\u3059\u3002"
    kr: "\uC778\uBCA4\uD1A0\uB9AC\uC5D0 \uBCF4\uC11D\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u80CC\u5305\u4E2D\u7684\u5B9D\u77F3\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng \u0111\u1EE7 ng\u1ECDc trong kho \u0111\u1ED3."
  - id: pet_training_upgrade_success
    en: Upgrade successful!
    jp: "\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u6210\u529F\uFF01"
    kr: "\uC5C5\uADF8\uB808\uC774\uB4DC \uC131\uACF5!"
    cn: "\u5347\u7EA7\u6210\u529F\uFF01"
    vn: "N\xE2ng c\u1EA5p th\xE0nh c\xF4ng!"
  - id: pet_training_upgrade_fail
