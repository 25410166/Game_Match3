    vn: "Pet \u0111\xE3 \u0111\u1EA1t c\u1EA5p t\u1ED1i \u0111a."
  - id: pet_training_no_player_data
    en: Not enough player data.
    jp: "\u30D7\u30EC\u30A4\u30E4\u30FC\u30C7\u30FC\u30BF\u304C\u4E0D\u8DB3\u3057\u3066\u3044\u307E\u3059\u3002"
    kr: "\uD50C\uB808\uC774\uC5B4 \uB370\uC774\uD130\uAC00 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u73A9\u5BB6\u6570\u636E\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng c\xF3 d\u1EEF li\u1EC7u ng\u01B0\u1EDDi ch\u01A1i."
  - id: pet_training_missing_gem_system
    en: Upgrade gem system is missing.
    jp: "\u5F37\u5316\u30B8\u30A7\u30E0\u30B7\u30B9\u30C6\u30E0\u304C\u898B\u3064\u304B\u308A\u307E\u305B\u3093\u3002"
    kr: "\uAC15\uD654 \uC82C \uC2DC\uC2A4\uD15C\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
    cn: "\u7F3A\u5C11\u5347\u7EA7\u5B9D\u77F3\u7CFB\u7EDF\u3002"
    vn: "Thi\u1EBFu h\u1EC7 th\u1ED1ng gem n\xE2ng c\u1EA5p."
  - id: pet_training_need_gem
    en: Select at least 1 gem to upgrade.
    jp: "\u5F37\u5316\u3059\u308B\u30B8\u30A7\u30E0\u30921\u3064\u4EE5\u4E0A\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
    kr: "\uAC15\uD654\uD560 \uC82C\uC744 1\uAC1C \uC774\uC0C1 \uC120\uD0DD\uD558\uC138\uC694."
    cn: "\u8BF7\u81F3\u5C11\u9009\u62E9 1 \u4E2A\u5B9D\u77F3\u8FDB\u884C\u5347\u7EA7\u3002"
    vn: "C\u1EA7n ch\u1ECDn \xEDt nh\u1EA5t 1 gem \u0111\u1EC3 n\xE2ng c\u1EA5p."
  - id: pet_training_not_enough_gems
    en: Not enough gems in inventory.
    jp: "\u30A4\u30F3\u30D9\u30F3\u30C8\u30EA\u306E\u30B8\u30A7\u30E0\u304C\u8DB3\u308A\u307E\u305B\u3093\u3002"
    kr: "\uC778\uBCA4\uD1A0\uB9AC\uC5D0 \uC82C\uC774 \uBD80\uC871\uD569\uB2C8\uB2E4."
    cn: "\u80CC\u5305\u4E2D\u7684\u5B9D\u77F3\u4E0D\u8DB3\u3002"
    vn: "Kh\xF4ng \u0111\u1EE7 gem trong t\xFAi \u0111\u1ED3."
