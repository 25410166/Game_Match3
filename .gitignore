# This .gitignore file should be placed at the root of your Unity project directory.

/[L|l]ibrary/
/[T|t]emp/
/[O|o]bj/
/[B|b]uild/
/[B|b]uilds/
/[L|l]ogs/
/[U|u]ser[D|d]ata/

# Memory dumps
*.kdmp
*.hdmp
*.mdmp

# Crashlytics
crashlytics-build.properties

# Asset Store tokens
AssetStoreTools*

# Autogenerated JetBrains Rider plugin files
.idea.*/

# Visual Studio cache directory
.vs/

# VS Code cache directory
.vscode/

# MSBuild/Visual Studio project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity micro-projects
Packages/manifest.json.bak
Packages/packages-lock.json

# Unity WebGL Build output
/[A|a]ssets/[S|s]treamingAssets/aa/*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db